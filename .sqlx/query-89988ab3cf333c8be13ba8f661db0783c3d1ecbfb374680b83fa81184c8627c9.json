  "query": "SELECT w.item_type, w.item_id, w.added_at,\n                  m.title, m.poster_path, m.release_date\n           FROM media.watchlist w\n           LEFT JOIN media.movies m ON m.id = w.item_id AND w.item_type = 'movie'\n           WHERE w.user_id = $1\n           ORDER BY w.added_at DESC",
