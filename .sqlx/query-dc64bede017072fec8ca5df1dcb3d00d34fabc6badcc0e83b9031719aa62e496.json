  "query": "SELECT f.id, f.owner_id, f.path, f.name,\n                  u.email        AS owner_email,\n                  u.display_name AS owner_display_name\n           FROM drive.folders f\n           JOIN core.users u ON u.id = f.owner_id\n           ORDER BY u.email, f.path",
