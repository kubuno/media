  "query": "SELECT a.id, a.title, a.release_year, a.cover_path, ar.name AS artist_name\n           FROM media.albums a\n           LEFT JOIN media.artists ar ON ar.id = a.artist_id\n           WHERE LOWER(a.title) LIKE $1\n           LIMIT $2",
