  "query": "SELECT a.id, a.title, a.release_year, a.cover_path, a.album_type,\n                  a.track_count, a.duration_secs, ar.name AS artist_name, ar.id AS artist_id\n           FROM media.albums a\n           LEFT JOIN media.artists ar ON ar.id = a.artist_id\n           ORDER BY a.title",
